{
  "name": "@dathomir/config",
  "version": "0.0.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "tsc": "./bin/tsc.js",
    "tsgo": "./bin/tsgo.js",
    "eslint": "./bin/eslint.js",
    "oxlint": "./bin/oxlint.js",
    "oxfmt": "./bin/oxfmt.js",
    "tsgolint": "./bin/tsgolint.js",
    "tsdown": "./bin/tsdown.js",
    "stryker": "./bin/stryker.js"
  },
  "exports": {
    "./templates/oxlint.template.ts": "./templates/oxlint.template.ts",
    "./templates/oxfmt.template.ts": "./templates/oxfmt.template.ts",
    "./templates/tsconfig.template.json": "./templates/tsconfig.template.json",
    "./templates/eslint.template.js": "./templates/eslint.template.js",
    "./tsdown": {
      "import": "./scripts/tsdown.mjs",
      "types": "./scripts/tsdown.d.ts"
    },
    "./oxlint": {
      "import": "./scripts/oxlint.mjs",
      "types": "./scripts/oxlint.d.ts"
    },
    "./types/*": "./types/*.ts"
  },
  "scripts": {
    "oxlint": "oxlint",
    "lint": "oxlint && eslint .",
    "lint:type-aware": "oxlint --type-aware && eslint ."
  },
  "dependencies": {
    "@stryker-mutator/api": "^9.5.1",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/vitest-runner": "^9.5.1",
    "@types/node": "24.2.0",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "catalog:",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-oxlint": "^1.24.0",
    "globals": "^16.4.0",
    "oxlint": "catalog:",
    "oxfmt": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "tsdown": "catalog:",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:"
  }
}
