{
  "name": "@playground/e2e",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:deps": "pnpm -r --filter @dathra/shared --filter @dathra/reactivity --filter @dathra/store --filter @dathra/runtime --filter @dathra/components --filter @dathra/core --filter @dathra/transformer --filter @dathra/plugin build",
    "dev": "pnpm build:deps && tsx server.ts",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --outDir dist/server --ssr src/entry-server.tsx",
    "build": "pnpm build:deps && pnpm build:client && pnpm build:server",
    "preview": "tsx server.ts --preview",
    "fmt": "oxfmt --ignore-path ../../.gitignore --no-error-on-unmatched-pattern --write \"**/*.{ts,tsx,js,mjs,cjs,cts,mts,json}\"",
    "fmt:check": "oxfmt --ignore-path ../../.gitignore --no-error-on-unmatched-pattern --check \"**/*.{ts,tsx,js,mjs,cjs,cts,mts,json}\"",
    "test": "pnpm --dir ../.. exec vitest run --config playgrounds/e2e/vitest.config.ts",
    "test:watch": "pnpm --dir ../.. exec vitest --config playgrounds/e2e/vitest.config.ts"
  },
  "dependencies": {
    "@dathra/components": "workspace:*",
    "@dathra/core": "workspace:*",
    "@dathra/runtime": "workspace:*",
    "@dathra/store": "workspace:*"
  },
  "devDependencies": {
    "@dathra/config": "workspace:*",
    "@dathra/plugin": "workspace:*",
    "@types/node": "catalog:",
    "playwright": "^1.56.1",
    "typescript": "catalog:",
    "tsx": "^4.20.6",
    "vite": "^6.4.1",
    "vitest": "catalog:"
  }
}
