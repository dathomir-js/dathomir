{
  "extends": "@dathra/config/templates/tsconfig.template.json",
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "@dathra/core": ["./src/jsx-runtime/index.ts"],
      "@dathra/core/jsx-runtime": ["./src/jsx-runtime/index.ts"],
      "@dathra/core/jsx-dev-runtime": ["./src/jsx-runtime/index.ts"],
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "@dathra/core"
  }
}
