{
  "name": "@dathra/core",
  "description": "dathra package",
  "version": "0.0.17",
  "private": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "type": "module",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:dathra/dathra.git"
  },
  "bugs": {
    "url": "https://github.com/dathra/dathra/issues",
    "email": "dathra@takumaru.dev"
  },
  "homepage": "https://github.com/dathra/dathra#readme",
  "author": "takuma-ru <takuma-ru@takumaru.dev> (https://github.com/takuma-ru/)",
  "keywords": [
    "dathra",
    "framework",
    "frontend",
    "javascript",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime/index.d.mts",
      "import": "./dist/jsx-runtime/index.mjs",
      "require": "./dist/jsx-runtime/index.cjs"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-runtime/index.d.mts",
      "import": "./dist/jsx-runtime/index.mjs",
      "require": "./dist/jsx-runtime/index.cjs"
    },
    "./reactivity": {
      "types": "./dist/reactivity/index.d.mts",
      "import": "./dist/reactivity/index.mjs",
      "require": "./dist/reactivity/index.cjs"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.mts",
      "import": "./dist/runtime/index.mjs",
      "require": "./dist/runtime/index.cjs"
    },
    "./store": {
      "types": "./dist/store/index.d.mts",
      "import": "./dist/store/index.mjs",
      "require": "./dist/store/index.cjs"
    },
    "./shared": {
      "types": "./dist/shared/index.d.mts",
      "import": "./dist/shared/index.mjs",
      "require": "./dist/shared/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint",
    "lint:type-aware": "oxlint --type-aware",
    "fmt": "oxfmt --ignore-path ../../.gitignore --write .",
    "fmt:check": "oxfmt --ignore-path ../../.gitignore --check .",
    "test": "vitest run --coverage --passWithNoTests",
    "version": "printf '\\033[1;36m%-10s | %-10s | %-10s\\033[0m\\n' tool version which; printf '%-10s | %-10s | %-10s\\n' ---------- ---------- ----------; printf '%-10s | %-10s | %-10s\\n' '@antfu/ni' '' \"$(which ni)\"; printf '%-10s | %-10s | %-10s\\n' node \"$(node -v)\" \"$(which node)\"; printf '%-10s | %-10s | %-10s\\n' pnpm \"v$(pnpm -v)\" \"$(which pnpm)\"",
    "release": "rlse"
  },
  "devDependencies": {
    "@dathra/config": "workspace:*",
    "@takuma-ru/rlse": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "happy-dom": "^20.5.3",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@dathra/components": "workspace:*",
    "@dathra/reactivity": "workspace:*",
    "@dathra/runtime": "workspace:*",
    "@dathra/store": "workspace:*",
    "@dathra/shared": "workspace:*"
  }
}