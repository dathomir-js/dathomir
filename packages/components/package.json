{
  "name": "@dathra/components",
  "description": "Web Components high-level API for Dathra framework",
  "type": "module",
  "version": "0.0.13",
  "private": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:dathra/dathra.git"
  },
  "bugs": {
    "url": "https://github.com/dathra/dathra/issues",
    "email": "dathra@takumaru.dev"
  },
  "homepage": "https://github.com/dathra/dathra#readme",
  "author": "takuma-ru <takuma-ru@takumaru.dev> (https://github.com/takuma-ru/)",
  "keywords": [
    "dathra",
    "web-components",
    "custom-elements",
    "shadow-dom",
    "framework",
    "frontend",
    "javascript",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./internal": {
      "types": "./dist/internal.d.mts",
      "import": "./dist/internal.mjs",
      "require": "./dist/internal.cjs"
    },
    "./ssr": {
      "types": "./dist/ssr/index.d.mts",
      "import": "./dist/ssr/index.mjs",
      "require": "./dist/ssr/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint",
    "lint:type-aware": "oxlint --type-aware",
    "fmt": "oxfmt --ignore-path ../../.gitignore --write .",
    "fmt:check": "oxfmt --ignore-path ../../.gitignore --check .",
    "test": "vitest run --coverage",
    "release": "rlse"
  },
  "devDependencies": {
    "@dathra/config": "workspace:*",
    "@takuma-ru/rlse": "catalog:",
    "@types/node": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "playwright": "^1.56.1",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@dathra/reactivity": "workspace:*",
    "@dathra/runtime": "workspace:*",
    "@dathra/shared": "workspace:*",
    "@dathra/store": "workspace:*"
  }
}